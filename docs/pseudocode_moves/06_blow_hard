# docs/pseudocode_moves/06_blow_hard

id							move_blow_hard
name						Blow Hard
element					force
moveType				attack
targetType			enemy
baseDamage			2
baseIterations	1
operations
	- applyAttune (
			element: this.element,
			targets: [caster]
		);

loopOperations
	- attack (
			baseDamage: this.baseDamage,
			baseIterations: this.baseIterations,
			element: this.element,
			targets: resolveTargets(this.owner, this.targetType),
		);
