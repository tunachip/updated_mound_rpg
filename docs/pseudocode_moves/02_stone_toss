# docs/pseudocode_moves/02_stone_toss

id							move_stone_toss
name						Stone Toss
element					stone
moveType				attack
targetType			enemy
baseDamage			2
baseIterations	1
operations
	- applyAttune (
			element: this.element,
			targets: [caster]
		);

loopOperations
	- attack (
			baseDamage: this.baseDamage,
			baseIterations: this.baseIterations,
			element: this.element,
			targets: resolveTargets(this.owner, this.targetType),
		);
